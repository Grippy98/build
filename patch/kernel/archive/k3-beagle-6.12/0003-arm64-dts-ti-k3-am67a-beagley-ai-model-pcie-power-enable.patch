From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Andrei Aldea <andrei@ti.com>
Date: Wed, 24 Jun 2026 22:25:00 +0000
Subject: [PATCH] arm64: dts: ti: k3-am67a-beagley-ai: model PCIe power enable

BeagleY-AI uses MCU_GPIO0_8 as PCIE_PWR_EN for the downstream PCIe slot
or attached switch. Model that signal as an always-on fixed 3.3 V
regulator so the drive is powered during boot without requiring PCIe host
driver support for a custom enable GPIO.
---
 arch/arm64/boot/dts/ti/k3-am67a-beagley-ai.dts | 21 +++++++++++++++++++--
 1 file changed, 19 insertions(+), 2 deletions(-)

diff --git a/arch/arm64/boot/dts/ti/k3-am67a-beagley-ai.dts b/arch/arm64/boot/dts/ti/k3-am67a-beagley-ai.dts
index c50ca32e8f93..c8d6d961a0c9 100644
--- a/arch/arm64/boot/dts/ti/k3-am67a-beagley-ai.dts
+++ b/arch/arm64/boot/dts/ti/k3-am67a-beagley-ai.dts
@@ -213,6 +213,20 @@ wlan_en: regulator-7 {
 		pinctrl-0 = <&wifi_en_pins_default>;
 	};
 
+	pcie_vdd_3v3: regulator-8 {
+		compatible = "regulator-fixed";
+		regulator-name = "pcie_vdd_3v3";
+		regulator-min-microvolt = <3300000>;
+		regulator-max-microvolt = <3300000>;
+		enable-active-high;
+		regulator-boot-on;
+		regulator-always-on;
+		vin-supply = <&vdd_3v3>;
+		gpio = <&mcu_gpio0 8 GPIO_ACTIVE_HIGH>;
+		pinctrl-names = "default";
+		pinctrl-0 = <&pcie_pwr_en_pins_default>;
+	};
+
 	leds {
 		compatible = "gpio-leds";
 		pinctrl-names = "default";
@@ -605,10 +619,14 @@ pcie_pins_default: pcie-default-pins {
 		pinctrl-single,pins = <
 			J722S_MCU_IOPAD(0x0018, PIN_OUTPUT, 7)	/* (B4) MCU_UART0_TXD.MCU_GPIO0_6 */
 			J722S_MCU_IOPAD(0x0014, PIN_INPUT, 7)	/* (B8) MCU_UART0_RXD.MCU_GPIO0_5 */ /* PCIE_DET_WAKE */
-			J722S_MCU_IOPAD(0x0020, PIN_OUTPUT, 7)	/* (C5) MCU_UART0_RTSn.MCU_GPIO0_8 */ /* PCIE_PWR_EN */
 		>;
 		bootph-all;
 	};
+	pcie_pwr_en_pins_default: pcie-pwr-en-default-pins {
+		pinctrl-single,pins = <
+			J722S_MCU_IOPAD(0x0020, PIN_OUTPUT, 7)	/* (C5) MCU_UART0_RTSn.MCU_GPIO0_8 */ /* PCIE_PWR_EN */
+		>;
+	};
 
 	mcu_i2c0_pins_default: mcu-i2c0-default-pins {
 		pinctrl-single,pins = <
@@ -1007,8 +1025,7 @@ &pcie0_rc {
 	pinctrl-0 = <&pcie_pins_default>;
 	phys = <&serdes1_pcie_link>;
 	phy-names = "pcie-phy";
 	num-lanes = <1>;
 	max-link-speed = <3>;
 	reset-gpios = <&mcu_gpio0 6 GPIO_ACTIVE_HIGH>;
-	enable-gpios = <&mcu_gpio0 8 GPIO_ACTIVE_HIGH>; /* Extra GPIO for pwr_en for BeagleY AI */
 };
-- 
