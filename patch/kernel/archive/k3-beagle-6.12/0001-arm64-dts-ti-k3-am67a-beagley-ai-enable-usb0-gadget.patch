From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Andrei Aldea <andrei@ti.com>
Date: Wed, 24 Jun 2026 14:55:00 +0000
Subject: [PATCH] arm64: dts: ti: k3-am67a-beagley-ai: enable USB0 gadget

Enable the USB0 wrapper and DWC3 controller on BeagleY-AI so configfs
gadgets have a UDC to bind. Force the controller into peripheral mode for
the board-side NCM plus ACM gadget use case.
---
 arch/arm64/boot/dts/ti/k3-am67a-beagley-ai.dts | 9 +++++++++
 1 file changed, 9 insertions(+)

diff --git a/arch/arm64/boot/dts/ti/k3-am67a-beagley-ai.dts b/arch/arm64/boot/dts/ti/k3-am67a-beagley-ai.dts
index ee3a953d38ef..d7f52427df1e 100644
--- a/arch/arm64/boot/dts/ti/k3-am67a-beagley-ai.dts
+++ b/arch/arm64/boot/dts/ti/k3-am67a-beagley-ai.dts
@@ -817,6 +817,15 @@ cc33xx: cc33xx@0 {
 	};
 };
 
+&usbss0 {
+	status = "okay";
+};
+
+&usb0 {
+	dr_mode = "peripheral";
+	status = "okay";
+};
+
 &mailbox0_cluster0 {
 	status = "okay";
 
-- 
2.39.5
